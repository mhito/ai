PROMPT="$*"

# Check if there's input from stdin (pipe)
STDIN_CONTENT=""
HAS_STDIN=false
if [ ! -t 0 ]; then
  # Read from stdin
  STDIN_CONTENT=$(cat)
  HAS_STDIN=true
  # Strip ANSI escape codes and check if stdin has any non-whitespace content
  STDIN_TRIMMED=$(printf '%s' "$STDIN_CONTENT" | sed 's/\x1b\[[0-9;]*m//g' | tr -d '\000' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
fi

# If there's stdin content, combine it with the prompt
if [ "$HAS_STDIN" = true ] && [ -n "$STDIN_TRIMMED" ]; then
  if [ -z "$PROMPT" ]; then
    # No prompt provided, just analyze the content
    PROMPT="Analyze this content:\n\n$STDIN_CONTENT"
  else
    # Combine prompt with stdin content
    PROMPT="$PROMPT\n\nContent:\n$STDIN_CONTENT"
  fi
elif [ "$HAS_STDIN" = true ] && [ -z "$STDIN_TRIMMED" ]; then
  # Stdin was provided but is empty or only whitespace
  echo "❌ Error: El contenido recibido está vacío"
  echo ""
  echo "Verifica que el archivo tenga contenido:"
  echo "  cat archivo.txt"
  exit 1
elif [ -z "$PROMPT" ]; then
  echo "Uso: aic \"tu pregunta\""
  echo "      cat archivo | aic \"pregunta sobre el archivo\""
  echo "      cat archivo | aic  (analiza el contenido)"
  exit 1
fi

# Load configuration: ENV first, then INI file
PROVIDER=$(get_config "AI_PROVIDER" "" "provider")

if [ -z "$PROVIDER" ]; then
  echo "❌ AI is not configured yet."
  echo ""
  echo "Please run the installer first:"
  echo "  cd ~/.ai && ./install.sh"
  echo ""
  echo "Or set AI_PROVIDER environment variable."
  exit 1
fi

case $PROVIDER in
  ollama)
    OLLAMA_MODEL=$(get_config "AI_OLLAMA_MODEL" "ollama" "model")
    OLLAMA_HAS_PROMPT=$(get_config "AI_OLLAMA_HAS_PROMPT" "ollama" "has_prompt")
    OLLAMA_HOST=$(get_config "AI_OLLAMA_HOST" "ollama" "host")
    call_ollama "$PROMPT" "$OLLAMA_MODEL" "$OLLAMA_HAS_PROMPT" "$OLLAMA_HOST"
    ;;
  deepseek)
    DEEPSEEK_API_KEY=$(get_config "AI_DEEPSEEK_API_KEY" "deepseek" "api_key")
    DEEPSEEK_MODEL=$(get_config "AI_DEEPSEEK_MODEL" "deepseek" "model")
    call_deepseek "$PROMPT" "$DEEPSEEK_API_KEY" "$DEEPSEEK_MODEL"
    ;;
  moonshot)
    MOONSHOT_API_KEY=$(get_config "AI_MOONSHOT_API_KEY" "moonshot" "api_key")
    MOONSHOT_MODEL=$(get_config "AI_MOONSHOT_MODEL" "moonshot" "model")
    call_moonshot "$PROMPT" "$MOONSHOT_API_KEY" "$MOONSHOT_MODEL"
    ;;
  *)
    echo "❌ Proveedor desconocido: $PROVIDER"
    exit 1
    ;;
esac
