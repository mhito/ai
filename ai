#!/bin/bash

CONFIG_DIR="$HOME/.ai"
CONFIG_FILE="$CONFIG_DIR/config"
PROMPT_FILE="$CONFIG_DIR/ai_prompt.txt"

# Helper function to read INI value
get_ini_value() {
  local section="$1"
  local key="$2"
  local config_file="$CONFIG_FILE"
  
  if [ ! -f "$config_file" ]; then
    return
  fi
  
  # If no section (global), read from top
  if [ -z "$section" ]; then
    grep "^${key}=" "$config_file" | head -n1 | cut -d'=' -f2-
  else
    # Read from specific section
    awk -v section="$section" -v key="$key" '
      /^\[.*\]$/ { in_section=0 }
      $0 == "["section"]" { in_section=1; next }
      in_section && $0 ~ "^"key"=" { sub("^"key"=", ""); print; exit }
    ' "$config_file"
  fi
}

# Get config value: first from ENV, then from INI
get_config() {
  local env_var="$1"
  local ini_section="$2"
  local ini_key="$3"
  
  # First try environment variable
  local env_value="${!env_var}"
  if [ -n "$env_value" ]; then
    echo "$env_value"
    return
  fi
  
  # Fallback to INI file
  get_ini_value "$ini_section" "$ini_key"
}

get_os_info() {
  local os_name="Unknown"
  local kernel="Unknown"
  local arch="Unknown"
  
  # Detect macOS
  if [[ "$OSTYPE" == "darwin"* ]]; then
    os_name="macOS $(sw_vers -productVersion 2>/dev/null || echo 'Unknown')"
    kernel="Darwin $(uname -r 2>/dev/null || echo 'Unknown')"
  elif [ -f /etc/os-release ]; then
    os_name=$(grep PRETTY_NAME /etc/os-release | cut -d'"' -f2)
    kernel=$(uname -r 2>/dev/null || echo "Unknown")
  else
    kernel=$(uname -r 2>/dev/null || echo "Unknown")
  fi
  
  arch=$(uname -m 2>/dev/null || echo "Unknown")
  
  echo "OS: $os_name, Kernel: $kernel, Arch: $arch"
}

uninstall_ai() {
  echo ""
  echo "🗑️  AI Uninstaller"
  echo ""
  echo "This will remove:"
  echo "  - ai and aic commands from your system"
  echo "  - Configuration files in ~/.ai/"
  echo ""
  echo -n "Are you sure you want to uninstall? (y/n): "
  read -r confirm
  
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "Uninstall cancelled."
    exit 0
  fi
  
  echo ""
  echo "Removing AI..."
  
  # Remove from /usr/local/bin
  if [ -f /usr/local/bin/ai ] || [ -L /usr/local/bin/ai ]; then
    sudo rm -f /usr/local/bin/ai
    echo "✓ Removed /usr/local/bin/ai"
  fi
  
  if [ -f /usr/local/bin/aic ] || [ -L /usr/local/bin/aic ]; then
    sudo rm -f /usr/local/bin/aic
    echo "✓ Removed /usr/local/bin/aic"
  fi
  
  # Remove configuration
  if [ -d "$CONFIG_DIR" ]; then
    rm -rf "$CONFIG_DIR"
    echo "✓ Removed configuration directory: $CONFIG_DIR"
  fi
  
  # Check and remove from PATH in .bashrc
  if grep -q "ai" ~/.bashrc 2>/dev/null; then
    echo ""
    echo -n "Remove AI from ~/.bashrc PATH? (y/n): "
    read -r remove_path
    if [ "$remove_path" = "y" ] || [ "$remove_path" = "Y" ]; then
      sed -i '/ai/d' ~/.bashrc
      echo "✓ Removed from ~/.bashrc"
    fi
  fi
  
  echo ""
  echo "✅ AI has been uninstalled successfully"
  echo ""
  exit 0
}

spinner() {
  local pid=$!
  local delay=0.1
  local spinstr='|/-\'
  
  while ps -p $pid > /dev/null 2>&1; do
    local temp=${spinstr#?}
    printf "\r [%c] " "$spinstr" >&2
    spinstr=$temp${spinstr%"$temp"}
    sleep $delay
  done

  printf "\r                    \r" >&2
}

call_ollama() {
  local prompt="$1"
  local model="$2"
  local has_prompt="$3"
  local host="$4"
  
  local os_context=$(get_os_info)
  
  local system_prompt=""
  if [ "$has_prompt" != "y" ]; then
    if [ -f "$PROMPT_FILE" ]; then
      local base_prompt=$(cat "$PROMPT_FILE")
      system_prompt="$base_prompt\n\nSystem context: $os_context"
    else
      system_prompt="You are a Linux command generator. Return ONLY the command, no explanations, no extra text. Just the raw command.\n\nSystem context: $os_context"
    fi
  fi
  
  local json_payload
  if [ -n "$system_prompt" ]; then
    json_payload=$(jq -n \
      --arg model "$model" \
      --arg prompt "$prompt" \
      --arg system "$system_prompt" \
      '{model: $model, prompt: $prompt, system: $system, stream: false}')
  else
    json_payload=$(jq -n \
      --arg model "$model" \
      --arg prompt "$prompt" \
      '{model: $model, prompt: $prompt, stream: false}')
  fi
  
  local response=$(mktemp)
  
  (
    curl -s "$host/api/generate" \
      -H "Content-Type: application/json" \
      -d "$json_payload" > "$response"
  ) &
  
  spinner
  
  local response_content=$(cat "$response")
  rm "$response"
  
  local command=$(echo "$response_content" | jq -r '.response // empty')
  
  if [ -z "$command" ]; then
    echo "❌ Error: no se pudo obtener respuesta"
    exit 1
  fi
  
  echo "$command"
}

call_deepseek() {
  local prompt="$1"
  local api_key="$2"
  local model="$3"
  
  local os_context=$(get_os_info)
  local system_content=""
  
  if [ -f "$PROMPT_FILE" ]; then
    local base_prompt=$(cat "$PROMPT_FILE")
    system_content="$base_prompt\n\nSystem context: $os_context"
  else
    system_content="You are an expert Linux terminal assistant.\n\nYour task is to convert natural language instructions into a single valid terminal command.\n\nSTRICT RULES:\n- Output ONLY the command\n- No explanations\n- No reasoning\n- No extra text\n- No markdown\n- No comments\n- Always return a single line\n- Use generic filenames if missing (e.g. archivo.tar.gz)\n- If unsure, output: echo \"command not found\"\n\nSystem context: $os_context"
  fi
  
  local json_payload=$(jq -n \
    --arg model "$model" \
    --arg prompt "$prompt" \
    --arg system "$system_content" \
    '{
      model: $model,
      messages: [
        {
          role: "system",
          content: $system
        },
        {
          role: "user",
          content: $prompt
        }
      ]
    }')
  
  local response=$(mktemp)
  
  (
    curl -s "https://api.deepseek.com/v1/chat/completions" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer $api_key" \
      -d "$json_payload" > "$response"
  ) &
  
  spinner
  
  local response_content=$(cat "$response")
  rm "$response"
  
  local command=$(echo "$response_content" | jq -r '.choices[0].message.content // empty')
  
  if [ -z "$command" ]; then
    echo "❌ Error: no se pudo obtener respuesta"
    exit 1
  fi
  
  echo "$command"
}

