prompt_execute() {
  local command="$1"
  
  printf "run? (Y/n): "
  
  read -r response
  
  # Clean response
  response=$(printf '%s' "$response" | tr -d '\r\n[:space:]')
  
  # Execute if empty (Enter) or Y/y
  case "$response" in
    ""|Y|y)
      bash -c "$command"
      ;;
    *)
      exit 0
      ;;
  esac
}

# Check for --uninstall flag
if [ "$1" = "--uninstall" ]; then
  uninstall_ai
fi

# Check for --model flag
if [ "$1" = "--model" ]; then
  PROVIDER=$(get_config "AI_PROVIDER" "" "provider")
  if [ -z "$PROVIDER" ]; then
    echo "❌ AI is not configured yet."
    exit 1
  fi

  case $PROVIDER in
    ollama)
      MODEL=$(get_config "AI_OLLAMA_MODEL" "ollama" "model")
      ;;
    deepseek)
      MODEL=$(get_config "AI_DEEPSEEK_MODEL" "deepseek" "model")
      ;;
    moonshot)
      MODEL=$(get_config "AI_MOONSHOT_MODEL" "moonshot" "model")
      ;;
    openai)
      MODEL=$(get_config "AI_OPENAI_MODEL" "openai" "model")
      ;;
    groq)
      MODEL=$(get_config "AI_GROQ_MODEL" "groq" "model")
      ;;
  esac

  echo "Provider: $PROVIDER"
  echo "Model:    ${MODEL:-<not set>}"
  exit 0
fi

# Check for execution mode flags
EXECUTE_MODE=false
if [ "$1" = "-x" ] || [ "$1" = "--execute" ]; then
  EXECUTE_MODE=true
  shift
fi

PROMPT="$*"

if [ -z "$PROMPT" ]; then
  echo "Uso: ai \"tu pregunta\""
  echo "      ai --uninstall  (to uninstall AI)"
  echo "      ai --model      (show current provider and model)"
  echo "      ai -x \"tu pregunta\"  (execute mode)"
  echo "      ai \"tu pregunta!\"  (execute mode with !)"
  exit 1
fi

# Check if prompt ends with ! (but not \!)
if [[ "$PROMPT" =~ !$ ]] && [[ ! "$PROMPT" =~ \\!$ ]]; then
  EXECUTE_MODE=true
  # Remove the trailing !
  PROMPT="${PROMPT%!}"
elif [[ "$PROMPT" =~ \\!$ ]]; then
  # Remove the escaped \!
  PROMPT="${PROMPT%\\!}!"
fi

# Load configuration: ENV first, then INI file
PROVIDER=$(get_config "AI_PROVIDER" "" "provider")

if [ -z "$PROVIDER" ]; then
  echo "❌ AI is not configured yet."
  echo ""
  echo "Please run the installer first:"
  echo "  cd ~/.ai && ./install.sh"
  echo ""
  echo "Or set AI_PROVIDER environment variable."
  exit 1
fi

COMMAND=""

case $PROVIDER in
  ollama)
    OLLAMA_MODEL=$(get_config "AI_OLLAMA_MODEL" "ollama" "model")
    OLLAMA_HAS_PROMPT=$(get_config "AI_OLLAMA_HAS_PROMPT" "ollama" "has_prompt")
    OLLAMA_HOST=$(get_config "AI_OLLAMA_HOST" "ollama" "host")
    COMMAND=$(call_ollama "$PROMPT" "$OLLAMA_MODEL" "$OLLAMA_HAS_PROMPT" "$OLLAMA_HOST")
    ;;
  deepseek)
    DEEPSEEK_API_KEY=$(get_config "AI_DEEPSEEK_API_KEY" "deepseek" "api_key")
    DEEPSEEK_MODEL=$(get_config "AI_DEEPSEEK_MODEL" "deepseek" "model")
    COMMAND=$(call_deepseek "$PROMPT" "$DEEPSEEK_API_KEY" "$DEEPSEEK_MODEL")
    ;;
  moonshot)
    MOONSHOT_API_KEY=$(get_config "AI_MOONSHOT_API_KEY" "moonshot" "api_key")
    MOONSHOT_MODEL=$(get_config "AI_MOONSHOT_MODEL" "moonshot" "model")
    COMMAND=$(call_moonshot "$PROMPT" "$MOONSHOT_API_KEY" "$MOONSHOT_MODEL")
    ;;
  openai)
    OPENAI_API_KEY=$(get_config "AI_OPENAI_API_KEY" "openai" "api_key")
    OPENAI_MODEL=$(get_config "AI_OPENAI_MODEL" "openai" "model")
    COMMAND=$(call_openai "$PROMPT" "$OPENAI_API_KEY" "$OPENAI_MODEL")
    ;;
  groq)
    GROQ_API_KEY=$(get_config "AI_GROQ_API_KEY" "groq" "api_key")
    GROQ_MODEL=$(get_config "AI_GROQ_MODEL" "groq" "model")
    COMMAND=$(call_groq "$PROMPT" "$GROQ_API_KEY" "$GROQ_MODEL")
    ;;
  *)
    echo "❌ Proveedor desconocido: $PROVIDER"
    exit 1
    ;;
esac

# Clean command (remove trailing whitespace and carriage returns)
COMMAND=$(echo "$COMMAND" | tr -d '\r' | sed 's/[[:space:]]*$//')

echo "$COMMAND"

if [ "$EXECUTE_MODE" = true ]; then
  prompt_execute "$COMMAND"
fi
